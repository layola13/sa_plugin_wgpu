@import "../wgpu.sal"

@test "wgpu shader desc validation"():
L_ENTRY:
    d = alloc WGPU_SHADER_DESC_SIZE
    call @sa_wgpu_shader_desc_init(&d)
    valid0 = call @sa_wgpu_shader_desc_is_valid(&d)
    call @sa_wgpu_shader_desc_set_source(&d, *WGPU_CUBE_SHADER, WGPU_CUBE_SHADER_LEN)
    call @sa_wgpu_shader_desc_set_label(&d, *WGPU_CUBE_VS_ENTRY, WGPU_CUBE_VS_ENTRY_LEN)
    valid1 = call @sa_wgpu_shader_desc_is_valid(&d)
    fmt_ok = call @sa_wgpu_shader_format_is_valid(WGPU_SHADER_FORMAT_WGSL)
    fmt_bad = call @sa_wgpu_shader_format_is_valid(9)
    validate_ok = call @sa_wgpu_shader_validate_mode_is_valid(WGPU_SHADER_VALIDATE_DISABLED)
    call @sa_wgpu_shader_desc_set_validate(&d, 7)
    valid2 = call @sa_wgpu_shader_desc_is_valid(&d)
    valid0_ok = eq valid0, 0
    valid1_ok = eq valid1, 1
    fmt_bad_ok = eq fmt_bad, 0
    valid2_ok = eq valid2, 0
    p1 = and valid0_ok, valid1_ok
    p2 = and fmt_ok, fmt_bad_ok
    p3 = and validate_ok, valid2_ok
    q = and p1, p2
    ok = and q, p3
    !d
    br ok -> L_OK, L_ERR
L_OK:
    return 0
L_ERR:
    panic(4199)

@test "wgpu render pipeline desc validation"():
L_ENTRY:
    attr0 = alloc WGPU_VERTEX_ATTR_SIZE
    attr1 = alloc WGPU_VERTEX_ATTR_SIZE
    desc = alloc WGPU_RENDER_PIPELINE_DESC_SIZE
    call @sa_wgpu_vertex_attr_init(&attr0, 0, 0, WGPU_VERTEX_FORMAT_FLOAT32X3)
    call @sa_wgpu_vertex_attr_init(&attr1, 1, 12, WGPU_VERTEX_FORMAT_FLOAT32X3)
    call @sa_wgpu_render_pipeline_desc_init(&desc)
    v0 = call @sa_wgpu_render_pipeline_desc_is_valid(&desc)
    v0_ok = eq v0, 0
    br v0_ok -> L_SET, L_ERR0
L_SET:
    call @sa_wgpu_render_pipeline_desc_set_shader(&desc, 44, *WGPU_CUBE_VS_ENTRY, WGPU_CUBE_VS_ENTRY_LEN, *WGPU_CUBE_FS_ENTRY, WGPU_CUBE_FS_ENTRY_LEN)
    call @sa_wgpu_render_pipeline_desc_set_vertex_layout(&desc, 24, &attr0, 2)
    v1 = call @sa_wgpu_render_pipeline_desc_is_valid(&desc)
    fmt_ok = call @sa_wgpu_vertex_format_is_valid(WGPU_VERTEX_FORMAT_FLOAT32X4)
    fmt_bad = call @sa_wgpu_vertex_format_is_valid(99)
    prim_ok = call @sa_wgpu_primitive_is_valid(WGPU_PRIMITIVE_TRIANGLE_LIST)
    prim_bad = call @sa_wgpu_primitive_is_valid(99)
    v1_ok = eq v1, 1
    fmt_bad_ok = eq fmt_bad, 0
    prim_bad_ok = eq prim_bad, 0
    a = and v1_ok, fmt_ok
    b = and fmt_bad_ok, prim_ok
    c = and prim_bad_ok, a
    ok = and c, b
    !desc
    !attr1
    !attr0
    br ok -> L_OK, L_ERR1
L_OK:
    return 0
L_ERR0:
    !desc
    !attr1
    !attr0
    panic(4200)
L_ERR1:
    panic(4201)

@test "wgpu render pipeline desc accepts multisample counts"():
L_ENTRY:
    attr0 = alloc WGPU_VERTEX_ATTR_SIZE
    desc = alloc WGPU_RENDER_PIPELINE_DESC_SIZE
    call @sa_wgpu_vertex_attr_init(&attr0, 0, 0, WGPU_VERTEX_FORMAT_FLOAT32X3)
    call @sa_wgpu_render_pipeline_desc_init(&desc)
    call @sa_wgpu_render_pipeline_desc_set_shader(&desc, 44, *WGPU_CUBE_VS_ENTRY, WGPU_CUBE_VS_ENTRY_LEN, *WGPU_CUBE_FS_ENTRY, WGPU_CUBE_FS_ENTRY_LEN)
    call @sa_wgpu_render_pipeline_desc_set_vertex_layout(&desc, 24, &attr0, 1)
    store desc+WGPU_RENDER_PIPELINE_DESC_sample_count, 4 as i32
    valid4 = call @sa_wgpu_render_pipeline_desc_is_valid(&desc)
    store desc+WGPU_RENDER_PIPELINE_DESC_sample_count, 3 as i32
    valid3 = call @sa_wgpu_render_pipeline_desc_is_valid(&desc)
    valid4_ok = eq valid4, 1
    valid3_ok = eq valid3, 0
    ok = and valid4_ok, valid3_ok
    !desc
    !attr0
    br ok -> L_OK, L_ERR

L_OK:
    return 0

L_ERR:
    panic(4205)

@test "wgpu draw desc validation"():
L_ENTRY:
    desc = alloc WGPU_DRAW_DESC_SIZE
    call @sa_wgpu_draw_desc_init(&desc)
    v0 = call @sa_wgpu_draw_desc_is_valid(&desc)
    v0_ok = eq v0, 0
    br v0_ok -> L_INDEXED, L_ERR0
L_INDEXED:
    call @sa_wgpu_draw_desc_set_resources(&desc, 10, 11, 12, 13)
    call @sa_wgpu_draw_desc_set_counts(&desc, WGPU_INDEX_U16, 36, 0)
    v1 = call @sa_wgpu_draw_desc_is_valid(&desc)
    idx_ok = call @sa_wgpu_index_format_is_valid(WGPU_INDEX_U32)
    load_ok = call @sa_wgpu_load_op_is_valid(WGPU_LOAD_OP_CLEAR)
    store_ok = call @sa_wgpu_store_op_is_valid(WGPU_STORE_OP_STORE)
    invalid_store = call @sa_wgpu_store_op_is_valid(9)
    v1_ok = eq v1, 1
    invalid_store_ok = eq invalid_store, 0
    a = and v1_ok, idx_ok
    b = and load_ok, store_ok
    c = and a, b
    ok = and c, invalid_store_ok
    br ok -> L_VERTEX_ONLY, L_ERR1
L_VERTEX_ONLY:
    call @sa_wgpu_draw_desc_set_resources(&desc, 10, 11, 0, 0)
    call @sa_wgpu_draw_desc_set_counts(&desc, WGPU_INDEX_NONE, 0, 24)
    v2 = call @sa_wgpu_draw_desc_is_valid(&desc)
    v2_ok = eq v2, 1
    !desc
    br v2_ok -> L_OK, L_ERR2
L_OK:
    return 0
L_ERR0:
    !desc
    panic(4202)
L_ERR1:
    !desc
    panic(4203)
L_ERR2:
    panic(4204)
