@sa_wgpu_draw_desc_is_valid(&desc: ptr) -> i32:
L_ENTRY:
    pipeline = load desc+WGPU_DRAW_DESC_pipeline as i64
    vertex = load desc+WGPU_DRAW_DESC_vertex as i64
    index = load desc+WGPU_DRAW_DESC_index as i64
    format = load desc+WGPU_DRAW_DESC_index_format as i32
    index_count = load desc+WGPU_DRAW_DESC_index_count as i64
    vertex_count = load desc+WGPU_DRAW_DESC_vertex_count as i64
    load_op = load desc+WGPU_DRAW_DESC_load_op as i32
    store_op = load desc+WGPU_DRAW_DESC_store_op as i32
    base_ok_a = sgt pipeline, 0
    base_ok_b = sgt vertex, 0
    base_ok = and base_ok_a, base_ok_b
    format_ok = call @sa_wgpu_index_format_is_valid(format)
    load_ok = call @sa_wgpu_load_op_is_valid(load_op)
    store_ok = call @sa_wgpu_store_op_is_valid(store_op)
    has_index_handle = sgt index, 0
    has_index_count = sgt index_count, 0
    has_index_format = ne format, WGPU_INDEX_NONE
    index_a = and has_index_handle, has_index_count
    indexed = and index_a, has_index_format
    has_vertices = sgt vertex_count, 0
    count_ok = or indexed, has_vertices
    a = and base_ok, format_ok
    b = and load_ok, store_ok
    c = and a, b
    ok = and c, count_ok
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !c
    !b
    !a
    !count_ok
    !has_vertices
    !indexed
    !index_a
    !has_index_format
    !has_index_count
    !has_index_handle
    !store_ok
    !load_ok
    !format_ok
    !base_ok
    !base_ok_b
    !base_ok_a
    !store_op
    !load_op
    !vertex_count
    !index_count
    !format
    !index
    !vertex
    !pipeline
    !desc
    return 1
L_FALSE:
    !ok
    !c
    !b
    !a
    !count_ok
    !has_vertices
    !indexed
    !index_a
    !has_index_format
    !has_index_count
    !has_index_handle
    !store_ok
    !load_ok
    !format_ok
    !base_ok
    !base_ok_b
    !base_ok_a
    !store_op
    !load_op
    !vertex_count
    !index_count
    !format
    !index
    !vertex
    !pipeline
    !desc
    return 0

#def WGPU_CUBE_VERTEX_USAGE = 40
#def WGPU_CUBE_INDEX_USAGE = 24
#def WGPU_CUBE_UNIFORM_USAGE = 72

#def WGPU_CUBE_VERTEX_BYTES = 576
#def WGPU_CUBE_INDEX_BYTES = 72
#def WGPU_CUBE_UNIFORM_BYTES = 16
#def WGPU_CUBE_UNIFORM_FRAME_BYTES = 16
#def WGPU_CUBE_UNIFORM_FRAMES_BYTES = 3840
#def WGPU_CUBE_INDEX_COUNT = 36
#def WGPU_CUBE_FRAME_COUNT = 240

#def WGPU_CUBE_CANVAS_SELECTOR_LEN = 12
#def WGPU_CUBE_FRAME_HANDLER_LEN = 18
#def WGPU_CUBE_VS_ENTRY_LEN = 7
#def WGPU_CUBE_FS_ENTRY_LEN = 7
#def WGPU_CUBE_SHADER_LEN = 1070

@const WGPU_CUBE_CANVAS_SELECTOR = utf8:"#wgpu-canvas"
@const WGPU_CUBE_FRAME_HANDLER = utf8:"sax_wgpucube_frame"
@const WGPU_CUBE_VS_ENTRY = utf8:"vs_main"
@const WGPU_CUBE_FS_ENTRY = utf8:"fs_main"

@const WGPU_CUBE_SHADER = utf8:"struct Uniforms {\n  angle_y: f32,\n  angle_x: f32,\n  aspect: f32,\n  _pad0: f32,\n};\n\n@group(0) @binding(0) var<uniform> uniforms: Uniforms;\n\nstruct VsIn {\n  @location(0) pos: vec3<f32>,\n  @location(1) color: vec3<f32>,\n};\n\nstruct VsOut {\n  @builtin(position) position: vec4<f32>,\n  @location(0) color: vec3<f32>,\n};\n\n@vertex\nfn vs_main(input: VsIn) -> VsOut {\n  let cy = cos(uniforms.angle_y);\n  let sy = sin(uniforms.angle_y);\n  let cx = cos(uniforms.angle_x);\n  let sx = sin(uniforms.angle_x);\n  let yawed = vec3<f32>(\n    input.pos.x * cy - input.pos.z * sy,\n    input.pos.y,\n    input.pos.x * sy + input.pos.z * cy,\n  );\n  let rotated = vec3<f32>(\n    yawed.x,\n    yawed.y * cx - yawed.z * sx,\n    yawed.y * sx + yawed.z * cx,\n  );\n  let view_z = rotated.z + 5.0;\n  let f = 1.55;\n  var out: VsOut;\n  out.position = vec4<f32>((rotated.x / uniforms.aspect) * f / view_z, rotated.y * f / view_z, 0.15 + view_z * 0.08, 1.0);\n  out.color = input.color;\n  return out;\n}\n\n@fragment\nfn fs_main(input: VsOut) -> @location(0) vec4<f32> {\n  return vec4<f32>(input.color, 1.0);\n}\n"

