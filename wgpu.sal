@sa_wgpu_render_pipeline_desc_is_valid(&desc: ptr) -> i32:
L_ENTRY:
    shader = load desc+WGPU_RENDER_PIPELINE_DESC_shader as i64
    vs_len = load desc+WGPU_RENDER_PIPELINE_DESC_vs_entry_len as i64
    fs_len = load desc+WGPU_RENDER_PIPELINE_DESC_fs_entry_len as i64
    stride = load desc+WGPU_RENDER_PIPELINE_DESC_vertex_stride as i64
    attrs = load desc+WGPU_RENDER_PIPELINE_DESC_attrs_len as i64
    primitive = load desc+WGPU_RENDER_PIPELINE_DESC_primitive as i32
    sample_count = load desc+WGPU_RENDER_PIPELINE_DESC_sample_count as i32
    shader_ok = sgt shader, 0
    entries_a = sgt vs_len, 0
    entries_b = sgt fs_len, 0
    entries_ok = and entries_a, entries_b
    stride_ok = sgt stride, 0
    attrs_min = sgt attrs, 0
    attrs_max = sle attrs, 4
    attrs_ok = and attrs_min, attrs_max
    primitive_ok = call @sa_wgpu_primitive_is_valid(primitive)
    samples_ok = eq sample_count, 1
    a = and shader_ok, entries_ok
    b = and stride_ok, attrs_ok
    c = and a, b
    d = and primitive_ok, samples_ok
    ok = and c, d
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !d
    !c
    !b
    !a
    !samples_ok
    !primitive_ok
    !attrs_ok
    !attrs_max
    !attrs_min
    !stride_ok
    !entries_ok
    !entries_b
    !entries_a
    !shader_ok
    !sample_count
    !primitive
    !attrs
    !stride
    !fs_len
    !vs_len
    !shader
    !desc
    return 1
L_FALSE:
    !ok
    !d
    !c
    !b
    !a
    !samples_ok
    !primitive_ok
    !attrs_ok
    !attrs_max
    !attrs_min
    !stride_ok
    !entries_ok
    !entries_b
    !entries_a
    !shader_ok
    !sample_count
    !primitive
    !attrs
    !stride
    !fs_len
    !vs_len
    !shader
    !desc
    return 0

@sa_wgpu_draw_desc_init(&desc: ptr) -> void:
L_ENTRY:
    store desc+WGPU_DRAW_DESC_pipeline, 0 as i64
    store desc+WGPU_DRAW_DESC_vertex, 0 as i64
    store desc+WGPU_DRAW_DESC_index, 0 as i64
    store desc+WGPU_DRAW_DESC_uniform, 0 as i64
    store desc+WGPU_DRAW_DESC_index_format, WGPU_INDEX_NONE as i32
    store desc+WGPU_DRAW_DESC_index_count, 0 as i64
    store desc+WGPU_DRAW_DESC_vertex_count, 0 as i64
    store desc+WGPU_DRAW_DESC_load_op, WGPU_LOAD_OP_CLEAR as i32
    store desc+WGPU_DRAW_DESC_store_op, WGPU_STORE_OP_STORE as i32
    store desc+WGPU_DRAW_DESC_clear_r, 20 as i32
    store desc+WGPU_DRAW_DESC_clear_g, 25 as i32
    store desc+WGPU_DRAW_DESC_clear_b, 30 as i32
    store desc+WGPU_DRAW_DESC_clear_a, 1000 as i32
    store desc+WGPU_DRAW_DESC_depth_load_op, WGPU_LOAD_OP_CLEAR as i32
    store desc+WGPU_DRAW_DESC_depth_store_op, WGPU_STORE_OP_STORE as i32
    store desc+WGPU_DRAW_DESC_depth_clear_milli, 1000 as i32
    !desc
    return

@sa_wgpu_draw_desc_set_resources(&desc: ptr, pipeline: i64, vertex: i64, index: i64, uniform: i64) -> void:
L_ENTRY:
