#def WGPU_VERTEX_FORMAT_UINT32 = 4

#def WGPU_PRIMITIVE_TRIANGLE_LIST = 0
#def WGPU_PRIMITIVE_TRIANGLE_STRIP = 1
#def WGPU_PRIMITIVE_LINE_LIST = 2
#def WGPU_PRIMITIVE_LINE_STRIP = 3
#def WGPU_PRIMITIVE_POINT_LIST = 4

#def WGPU_CULL_NONE = 0
#def WGPU_CULL_FRONT = 1
#def WGPU_CULL_BACK = 2

#def WGPU_INDEX_NONE = 0
#def WGPU_INDEX_U16 = 1
#def WGPU_INDEX_U32 = 2

#def WGPU_LOAD_OP_LOAD = 0
#def WGPU_LOAD_OP_CLEAR = 1
#def WGPU_STORE_OP_DISCARD = 0
#def WGPU_STORE_OP_STORE = 1

#def WGPU_DEPTH_COMPARE_LESS = 0
#def WGPU_DEPTH_COMPARE_LESS_EQUAL = 1
#def WGPU_DEPTH_COMPARE_ALWAYS = 2

#def WGPU_SHADER_FORMAT_WGSL = 1
#def WGPU_SHADER_VALIDATE_DISABLED = 0
#def WGPU_SHADER_VALIDATE_ENABLED = 1

#def WGPU_SHADER_DESC_format = +0
#def WGPU_SHADER_DESC_flags = +4
#def WGPU_SHADER_DESC_source_ptr = +8
#def WGPU_SHADER_DESC_source_len = +16
#def WGPU_SHADER_DESC_label_ptr = +24
#def WGPU_SHADER_DESC_label_len = +32
#def WGPU_SHADER_DESC_validate = +40
#def WGPU_SHADER_DESC_SIZE = 48

#def WGPU_VERTEX_ATTR_shader_location = +0
