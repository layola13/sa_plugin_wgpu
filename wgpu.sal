@sa_wgpu_shader_desc_init(&desc: ptr) -> void:
L_ENTRY:
    store desc+WGPU_SHADER_DESC_format, WGPU_SHADER_FORMAT_WGSL as i32
    store desc+WGPU_SHADER_DESC_flags, 0 as i32
    store desc+WGPU_SHADER_DESC_source_ptr, 0 as i64
    store desc+WGPU_SHADER_DESC_source_len, 0 as i64
    store desc+WGPU_SHADER_DESC_label_ptr, 0 as i64
    store desc+WGPU_SHADER_DESC_label_len, 0 as i64
    store desc+WGPU_SHADER_DESC_validate, WGPU_SHADER_VALIDATE_ENABLED as i32
    !desc
    return

@sa_wgpu_shader_desc_set_source(&desc: ptr, source_ptr: ptr, source_len: i64) -> void:
L_ENTRY:
    store desc+WGPU_SHADER_DESC_source_ptr, source_ptr as ptr
    store desc+WGPU_SHADER_DESC_source_len, source_len as i64
    !source_len
    !source_ptr
    !desc
    return

@sa_wgpu_shader_desc_set_label(&desc: ptr, label_ptr: ptr, label_len: i64) -> void:
L_ENTRY:
    store desc+WGPU_SHADER_DESC_label_ptr, label_ptr as ptr
    store desc+WGPU_SHADER_DESC_label_len, label_len as i64
    !label_len
    !label_ptr
    !desc
    return

@sa_wgpu_shader_desc_set_validate(&desc: ptr, validate: i32) -> void:
L_ENTRY:
    store desc+WGPU_SHADER_DESC_validate, validate as i32
    !validate
    !desc
    return

@sa_wgpu_shader_format_is_valid(format: i32) -> i32:
L_ENTRY:
    ok = eq format, WGPU_SHADER_FORMAT_WGSL
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !format
    return 1
L_FALSE:
    !ok
    !format
    return 0

@sa_wgpu_shader_validate_mode_is_valid(validate: i32) -> i32:
L_ENTRY:
    off = eq validate, WGPU_SHADER_VALIDATE_DISABLED
    on = eq validate, WGPU_SHADER_VALIDATE_ENABLED
    ok = or off, on
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !on
    !off
    !validate
    return 1
L_FALSE:
    !ok
    !on
    !off
    !validate
    return 0

@sa_wgpu_shader_desc_is_valid(&desc: ptr) -> i32:
L_ENTRY:
    format = load desc+WGPU_SHADER_DESC_format as i32
    source_ptr = load desc+WGPU_SHADER_DESC_source_ptr as i64
    source_len = load desc+WGPU_SHADER_DESC_source_len as i64
    validate = load desc+WGPU_SHADER_DESC_validate as i32
    format_ok = call @sa_wgpu_shader_format_is_valid(format)
    ptr_ok = ne source_ptr, 0
    len_ok = sgt source_len, 0
    source_ok = and ptr_ok, len_ok
    validate_ok = call @sa_wgpu_shader_validate_mode_is_valid(validate)
    a = and format_ok, source_ok
    ok = and a, validate_ok
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !a
    !validate_ok
    !source_ok
    !len_ok
    !ptr_ok
    !format_ok
    !validate
    !source_len
    !source_ptr
    !format
    !desc
    return 1
L_FALSE:
    !ok
    !a
    !validate_ok
    !source_ok
    !len_ok
    !ptr_ok
    !format_ok
    !validate
    !source_len
    !source_ptr
    !format
    !desc
    return 0

@sa_wgpu_vertex_attr_init(&attr: ptr, shader_location: i32, offset: i64, format: i32) -> void:
L_ENTRY:
    store attr+WGPU_VERTEX_ATTR_shader_location, shader_location as i32
    store attr+WGPU_VERTEX_ATTR_offset, offset as i64
    store attr+WGPU_VERTEX_ATTR_format, format as i32
    !format
    !offset
    !shader_location
    !attr
    return

@sa_wgpu_vertex_format_is_valid(format: i32) -> i32:
L_ENTRY:
    f2 = eq format, WGPU_VERTEX_FORMAT_FLOAT32X2
    f3 = eq format, WGPU_VERTEX_FORMAT_FLOAT32X3
    f4 = eq format, WGPU_VERTEX_FORMAT_FLOAT32X4
    u1 = eq format, WGPU_VERTEX_FORMAT_UINT32
    a = or f2, f3
    b = or f4, u1
    ok = or a, b
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !b
    !a
    !u1
    !f4
    !f3
    !f2
    !format
    return 1
L_FALSE:
    !ok
    !b
    !a
    !u1
    !f4
    !f3
    !f2
    !format
    return 0

@sa_wgpu_primitive_is_valid(primitive: i32) -> i32:
L_ENTRY:
    t0 = eq primitive, WGPU_PRIMITIVE_TRIANGLE_LIST
    t1 = eq primitive, WGPU_PRIMITIVE_TRIANGLE_STRIP
    l0 = eq primitive, WGPU_PRIMITIVE_LINE_LIST
    l1 = eq primitive, WGPU_PRIMITIVE_LINE_STRIP
    p0 = eq primitive, WGPU_PRIMITIVE_POINT_LIST
    a = or t0, t1
    b = or l0, l1
    c = or a, b
    ok = or c, p0
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !c
    !b
    !a
    !p0
    !l1
    !l0
    !t1
    !t0
    !primitive
    return 1
L_FALSE:
    !ok
    !c
    !b
    !a
    !p0
    !l1
    !l0
    !t1
    !t0
    !primitive
    return 0

@sa_wgpu_index_format_is_valid(format: i32) -> i32:
L_ENTRY:
    none = eq format, WGPU_INDEX_NONE
    u16 = eq format, WGPU_INDEX_U16
    u32 = eq format, WGPU_INDEX_U32
    any_index = or u16, u32
    ok = or none, any_index
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !any_index
    !u32
    !u16
    !none
    !format
    return 1
L_FALSE:
    !ok
    !any_index
    !u32
    !u16
    !none
    !format
    return 0

@sa_wgpu_load_op_is_valid(op: i32) -> i32:
L_ENTRY:
    load = eq op, WGPU_LOAD_OP_LOAD
    clear = eq op, WGPU_LOAD_OP_CLEAR
    ok = or load, clear
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !clear
    !load
    !op
    return 1
L_FALSE:
    !ok
    !clear
    !load
    !op
    return 0

@sa_wgpu_store_op_is_valid(op: i32) -> i32:
L_ENTRY:
    discard = eq op, WGPU_STORE_OP_DISCARD
    store = eq op, WGPU_STORE_OP_STORE
    ok = or discard, store
    br ok -> L_TRUE, L_FALSE
L_TRUE:
    !ok
    !store
    !discard
    !op
    return 1
L_FALSE:
    !ok
    !store
    !discard
    !op
    return 0

@sa_wgpu_render_pipeline_desc_init(&desc: ptr) -> void:
L_ENTRY:
    store desc+WGPU_RENDER_PIPELINE_DESC_shader, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_vs_entry_ptr, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_vs_entry_len, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_fs_entry_ptr, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_fs_entry_len, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_vertex_stride, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_attrs_ptr, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_attrs_len, 0 as i64
    store desc+WGPU_RENDER_PIPELINE_DESC_primitive, WGPU_PRIMITIVE_TRIANGLE_LIST as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_cull_mode, WGPU_CULL_NONE as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_depth_enabled, 1 as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_depth_write_enabled, 1 as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_depth_compare, WGPU_DEPTH_COMPARE_LESS as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_uniform_binding, 0 as i32
    store desc+WGPU_RENDER_PIPELINE_DESC_sample_count, 1 as i32
    !desc
    return

@sa_wgpu_render_pipeline_desc_set_shader(&desc: ptr, shader: i64, vs_entry: ptr, vs_len: i64, fs_entry: ptr, fs_len: i64) -> void:
L_ENTRY:
    store desc+WGPU_RENDER_PIPELINE_DESC_shader, shader as i64
