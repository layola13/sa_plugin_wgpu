#def WGPU_RENDER_PIPELINE_DESC_uniform_binding = +84
#def WGPU_RENDER_PIPELINE_DESC_sample_count = +88
#def WGPU_RENDER_PIPELINE_DESC_SIZE = 96

#def WGPU_DRAW_DESC_pipeline = +0
#def WGPU_DRAW_DESC_vertex = +8
#def WGPU_DRAW_DESC_index = +16
